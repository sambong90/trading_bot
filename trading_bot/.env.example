# Copy this file to trading_bot/.env and fill values. KEEP .env OUT OF VERSION CONTROL.

# --- Upbit API ---
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 텔레그램 관리자 user_id (숫자). 설정 시 해당 사용자만 /pause /resume /panic 명령 사용 가능.
# Telegram 앱에서 @userinfobot 에게 메시지 보내면 자신의 user_id 확인 가능.
TELEGRAM_ADMIN_USER_ID=
TELEGRAM_ALERT_LEVEL=TRADE

# --- Trading Mode ---
TRADING_MODE=paper
ENABLE_AUTO_TRADING=0
ENABLE_AUTO_LIVE=0

# --- Scheduler ---
TRADING_INTERVAL_MINUTES=5
# 캔들 마감 후 실행 오프셋(초). 기본 60 = 정시 1분 후(HH:01:00). 1h봉 종가 확정 보장.
CANDLE_SYNC_OFFSET_SEC=60

# --- Position Sizing ---
ACCOUNT_VALUE=1000000

# --- Risk Management ---
HARD_STOP_LOSS_PCT=-10.0
SLIPPAGE_GUARD_PCT=3.0

# --- Ticker Filter ---
# 쉼표 구분 특정 티커만 사용 (비워두면 거래대금 상위 60개 자동 선택)
TICKERS=
TICKER_TOP_N=60
